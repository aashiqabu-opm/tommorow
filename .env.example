NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Outbound alerts (all optional — alerts are silently skipped if unset)
NEXT_PUBLIC_APP_URL=https://opmoffice.vercel.app

# Email via Resend (resend.com — free tier is enough)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=OPM Office <office@yourdomain.com>

# Daily digest cron protection (any long random string; set the same value in Vercel)
CRON_SECRET=generate-a-long-random-string

# WhatsApp via Twilio (optional)
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Approved Meta template SIDs for business-initiated WhatsApp messages (see
# WHATSAPP_TEMPLATES.md). If unset, those sends fall back to free-form text
# (fine on the Twilio sandbox; required once on a production WhatsApp number).
TWILIO_TEMPLATE_NEW_BILL_SID=HXxxxxxxxx
TWILIO_TEMPLATE_REJECTED_SID=HXxxxxxxxx

# AI bill extraction via Claude (optional — payment form auto-fills from uploaded bills)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ─── Agent watchdog (Phase 1: /api/cron/agent-monitor, runs every 5 min) ───
# All optional — each probe self-skips if its vars are missing.
OPM_WEBSITE_URL=https://opmcinemas.com
# Claude model for incident triage (only invoked on red events). Defaults to the
# codebase model if unset.
AGENT_MODEL=claude-opus-4-8
# Don't re-page the same incident more often than this.
ALERT_COOLDOWN_MINUTES=15
# Treat a website response slower than this (ms) as a warning.
AGENT_SLOW_RESPONSE_MS=3000
# GitHub CI check (optional): a fine-grained token with read access + "owner/repo".
GITHUB_TOKEN=ghp_xxxxxxxx
GITHUB_REPO=aashiqabu-opm/tommorow
# Supabase storage usage check (optional): management API token + project ref.
SUPABASE_MGMT_TOKEN=sbp_xxxxxxxx
SUPABASE_PROJECT_REF=your-project-ref
